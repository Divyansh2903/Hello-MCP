# Supabase project ref id (Dashboard → Project Settings → General → Reference ID).
# Drives OAuth discovery + JWT verification. Public identifier, not a secret.
MCP_USE_OAUTH_SUPABASE_PROJECT_ID=your-project-ref

# Backend Todo API base URL (no trailing slash).
TODO_API_URL=http://localhost:8787

# Legacy HS256 Supabase projects only (new projects use ES256 + JWKS, leave unset):
# MCP_USE_OAUTH_SUPABASE_JWT_SECRET=your-jwt-secret
